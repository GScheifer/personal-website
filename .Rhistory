library(haven)
library(dplyr)
df <- read_sav("/data/cleaned_data.sav")
df <- read_sav("data/cleaned_data.sav")
View(df)
head(df)
# 1. Randomize row order
set.seed(1234)
df <- df %>% slice_sample(n = n())
df <- df %>% slice_sample(prop = 1)
# 2. Reduce precision for height and weight if present
# Adjust variable names if needed
if ("height" %in% names(df)) {
df <- df %>% mutate(height = round(height / 5) * 5)   # nearest 5 cm
}
if ("weight" %in% names(df)) {
df <- df %>% mutate(weight = round(weight / 5) * 5)   # nearest 5 kg
}
# 3. Check for unique rows across all remaining variables
risk_check <- df %>%
count(across(everything()), name = "freq") %>%
arrange(freq)
unique_profiles <- risk_check %>% filter(freq == 1)
cat("Number of unique profiles:", nrow(unique_profiles), "\n")
set.seed(1234)
# Shuffle row order
df <- df %>% slice_sample(prop = 1)
# Reduce precision of weight and height
if ("A53" %in% names(df)) {
df <- df %>% mutate(A53 = round(A53 / 5) * 5)   # weight to nearest 5 kg
}
if ("A54" %in% names(df)) {
df <- df %>% mutate(A54 = round(A54 / 5) * 5)   # height to nearest 5 cm
}
# Overwrite the original file
write_sav(df, "cleaned_data.sav")
file.exists("images/dog.jpg")
library(quarto)
quarto_version()
system("quarto --version", intern = TRUE)
